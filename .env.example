# =============================================================================
# TaskChain — Environment Variables
# Copy to .env and fill in all values before running.
# Never commit .env to git — private keys and API keys are sensitive.
# =============================================================================

# ── Avalanche Fuji C-Chain ────────────────────────────────────────────────────
# Public RPC endpoint for Fuji testnet. No API key required.
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ── Wallet Private Keys ───────────────────────────────────────────────────────
# Generate fresh wallets: npx ts-node scripts/generate-wallets.ts
# Use TESTNET-ONLY wallets — never use mainnet keys here.

# Deployer: pays gas for contract deployment and agent registration.
# Fund with test AVAX: https://faucet.avax.network/
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Router: signs x402 USDC payments to sub-agents (0.01 USDC per call).
# Fund with test USDC: https://faucet.circle.com/ (select Avalanche Fuji)
ROUTER_AGENT_PRIVATE_KEY=
ROUTER_AGENT_ADDRESS=

# Translator: receives USDC, calls recordCompletion (needs AVAX for gas).
# Fund with test AVAX: https://faucet.avax.network/
TRANSLATOR_AGENT_PRIVATE_KEY=
TRANSLATOR_AGENT_ADDRESS=

# Analyzer: receives USDC, calls recordCompletion (needs AVAX for gas).
# Fund with test AVAX: https://faucet.avax.network/
ANALYZER_AGENT_PRIVATE_KEY=
ANALYZER_AGENT_ADDRESS=

# Writer: receives USDC, calls recordCompletion (needs AVAX for gas).
# Fund with test AVAX: https://faucet.avax.network/
WRITER_AGENT_PRIVATE_KEY=
WRITER_AGENT_ADDRESS=

# ── Smart Contract Addresses ──────────────────────────────────────────────────
# Populated automatically by: npx ts-node scripts/deploy.ts
# Already deployed on Fuji: 0xdDe74f96020161783d2663999f531a316904105e
AGENT_REGISTRY_ADDRESS=0xdDe74f96020161783d2663999f531a316904105e

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for real AI translation/writing. Get key: https://console.anthropic.com/
# Usage limit: keep below $0.10/hour during testing.
# If you have no credits, set MOCK_* flags below to test the x402 flow.
ANTHROPIC_API_KEY=

# ── x402 Payment Facilitator ──────────────────────────────────────────────────
# Local facilitator handles USDC settlement on Fuji.
# docker-compose overrides this to http://facilitator:4021 automatically.
PAYMENT_FACILITATOR_URL=http://localhost:4021
FACILITATOR_PORT=4021

# ── USDC on Fuji Testnet ──────────────────────────────────────────────────────
# Circle's testnet USDC — supports EIP-3009 (gasless transfers).
USDC_CONTRACT_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# ── Agent Ports ───────────────────────────────────────────────────────────────
TRANSLATOR_PORT=3001
ANALYZER_PORT=3002
WRITER_PORT=3003
ROUTER_PORT=3000
FACILITATOR_PORT=4021

# ── Mock Mode (bypass Anthropic API for x402 payment loop testing) ────────────
# Set these to "true" to test the full payment pipeline without API credits.
# Remove or set to "false" when you have Anthropic credits loaded.
MOCK_TRANSLATION=true
MOCK_DECOMPOSITION=true
MOCK_ANALYSIS=true
MOCK_WRITING=true

# ── Phase 5: PostgreSQL + Auth ────────────────────────────────────────────────
# PostgreSQL connection string.
# For local dev without Docker: postgresql://taskchain:taskchain@localhost:5432/taskchain
# docker-compose sets this automatically for the api service — no need to change.
DATABASE_URL=postgresql://taskchain:taskchain@localhost:5432/taskchain

# JWT signing secret — change to a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=taskchain-dev-secret-change-in-prod

# ── Privy (wallet auth) ───────────────────────────────────────────────────────
# Create an app at https://privy.io → Dashboard → Create App
# Set "Allowed origins" to http://localhost:3010 for local dev.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Same App ID exposed to the Next.js client (browser).
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Frontend API URLs ─────────────────────────────────────────────────────────
# Server-side (Docker inter-container): set automatically by docker-compose
API_URL=http://localhost:3005
# Client-side (browser): must be reachable from user's machine
NEXT_PUBLIC_API_URL=http://localhost:3005

# ── Dev/Test: bypass Privy token verification ─────────────────────────────────
# Set to "true" to skip Privy verification in test-auth.ts and local dev.
# POST /auth/verify will accept { walletAddress } directly instead of a Privy token.
# NEVER set to "true" in production.
PRIVY_SKIP_VERIFY=false

# ── Phase 6: Dynamic Agent Marketplace + Runner ───────────────────────────────
# 32-byte (64 hex char) master key for AES-256-GCM encryption of agent wallet private keys.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# All agent private keys stored in DB are encrypted with this key. Rotating it requires
# re-encrypting all stored keys — don't lose it.
AGENT_MASTER_KEY=

# URL where the AgentRunner is reachable (used by the API to set agent endpoint URLs).
# docker-compose sets this to http://runner:4000 automatically for the api service.
# For local dev without Docker, keep the default.
RUNNER_URL=http://localhost:4000

# Port the AgentRunner listens on.
RUNNER_PORT=4000

# ── Phase 8: SatisfactionEscrow + Task Execution ─────────────────────────────

# Deployed SatisfactionEscrow contract address on Fuji.
# Run: npx ts-node scripts/deploy-escrow.ts
# Already deployed: 0x7425633DCe485a08f7Cb2EDF01743307D25C8436
SATISFACTION_ESCROW_ADDRESS=0x7425633DCe485a08f7Cb2EDF01743307D25C8436

# Platform treasury wallet — receives 5% fee from each approved task.
# Fund with AVAX for gas if it needs to interact with contracts.
TREASURY_ADDRESS=

# Admin wallet address — required for GET /admin/treasury access.
# Must match the deployer or a dedicated admin wallet.
ADMIN_WALLET_ADDRESS=

# Internal key for task executor → runner bypass (skips x402 payment check).
# Must match AGENT_MASTER_KEY — the executor sends this as X-Internal-Key header.
# (Already set above as AGENT_MASTER_KEY, referenced internally.)

# ── Frontend: Fuji RPC + Escrow ───────────────────────────────────────────────
# Fuji RPC URL exposed to the Next.js browser client (for read-only contract calls).
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployed SatisfactionEscrow address exposed to the Next.js browser client.
NEXT_PUBLIC_ESCROW_ADDRESS=0x7425633DCe485a08f7Cb2EDF01743307D25C8436

# ── Phase 9: $TASK Token + Staking ───────────────────────────────────────────

# Deployed TaskToken (ERC-20) address on Fuji.
# Run: npx ts-node scripts/deploy-token.ts
TASK_TOKEN_ADDRESS=

# Deployed TaskStaking contract address on Fuji.
TASK_STAKING_ADDRESS=

# Same addresses exposed to the Next.js browser client.
NEXT_PUBLIC_TASK_TOKEN_ADDRESS=
NEXT_PUBLIC_TASK_STAKING_ADDRESS=

# Note: SatisfactionEscrow constructor now takes (usdcAddress, taskTokenAddress, treasuryAddress).
# Re-deploy with: npx ts-node scripts/deploy-escrow.ts (after filling TASK_TOKEN_ADDRESS)
