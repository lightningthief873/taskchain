# =============================================================================
# TaskChain — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all empty values
# 3. Run:             docker compose up --build
# Never commit .env to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev without Docker: postgresql://taskchain:taskchain@localhost:5433/taskchain
# Docker: overridden automatically in docker-compose.yml (do not change)
DATABASE_URL=postgresql://taskchain:taskchain@localhost:5433/taskchain

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Dev/test only — set true to skip Privy JWT verification (accepts raw walletAddress).
# NEVER true in production.
PRIVY_SKIP_VERIFY=false

# ── Privy (wallet login) ──────────────────────────────────────────────────────
# Create an app at https://privy.io → Dashboard → Create App
# Set Allowed Origins to http://localhost:3010 for local dev.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=   # same value as PRIVY_APP_ID

# ── Anthropic (AI agent execution) ───────────────────────────────────────────
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Avalanche Fuji ────────────────────────────────────────────────────────────
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployer wallet — needs test AVAX for gas. Fund: https://faucet.avax.network/
DEPLOYER_PRIVATE_KEY=

# ── Contract Addresses (Fuji) ─────────────────────────────────────────────────
# Already deployed — do not change unless you redeploy.
AGENT_REGISTRY_ADDRESS=0xdDe74f96020161783d2663999f531a316904105e
USDC_CONTRACT_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# Deploy with: npx ts-node scripts/deploy-token.ts
TASK_TOKEN_ADDRESS=0x867Cef12254b8BbeE37530F76477e4Da1bBBb6E4
TASK_STAKING_ADDRESS=0x463C3dCe125e287c895dc2F2cb387EC75E7F055b

# Deploy with: npx ts-node scripts/deploy-escrow.ts
SATISFACTION_ESCROW_ADDRESS=0x07893fa3b4923c069AC14725B1e85E951C82759F

# ── Frontend Public Contract Addresses ───────────────────────────────────────
# These are read by the user's browser — must match the values above.
NEXT_PUBLIC_ESCROW_ADDRESS=0x07893fa3b4923c069AC14725B1e85E951C82759F
NEXT_PUBLIC_TASK_TOKEN_ADDRESS=0x867Cef12254b8BbeE37530F76477e4Da1bBBb6E4
NEXT_PUBLIC_TASK_STAKING_ADDRESS=0x463C3dCe125e287c895dc2F2cb387EC75E7F055b

# ── API / Runner ──────────────────────────────────────────────────────────────
PORT=3005
RUNNER_PORT=4000

# Docker-compose overrides these automatically — only change for local dev.
RUNNER_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3005

# 32-byte hex key for AES-256-GCM encryption of agent wallet private keys in DB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_MASTER_KEY=

# ── Treasury / Admin ──────────────────────────────────────────────────────────
# Receives 5% platform fee from each approved pipeline.
TREASURY_ADDRESS=
# Gates GET /admin/treasury endpoint.
ADMIN_WALLET_ADDRESS=

# ── x402 Facilitator ──────────────────────────────────────────────────────────
PAYMENT_FACILITATOR_URL=http://localhost:4021
FACILITATOR_PORT=4021
