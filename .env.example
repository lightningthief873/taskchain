# Avalanche Fuji C-Chain
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Wallet private keys (use fresh testnet-only wallets — run: npx ts-node scripts/generate-wallets.ts)
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

ROUTER_AGENT_PRIVATE_KEY=
ROUTER_AGENT_ADDRESS=

TRANSLATOR_AGENT_PRIVATE_KEY=
TRANSLATOR_AGENT_ADDRESS=

ANALYZER_AGENT_PRIVATE_KEY=
ANALYZER_AGENT_ADDRESS=

WRITER_AGENT_PRIVATE_KEY=
WRITER_AGENT_ADDRESS=

# Contract addresses (populated by scripts/deploy.ts)
AGENT_REGISTRY_ADDRESS=

# AI
ANTHROPIC_API_KEY=

# x402 payments
# Local facilitator (recommended for Fuji — run: npx ts-node x402/facilitator.ts)
PAYMENT_FACILITATOR_URL=http://localhost:4021
FACILITATOR_PORT=4021

# Optional: Bypass Anthropic API for x402 loop testing
# MOCK_TRANSLATION=true

# USDC on Fuji testnet (Circle's testnet USDC)
USDC_CONTRACT_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# Agent ports
TRANSLATOR_PORT=3001
ANALYZER_PORT=3002
WRITER_PORT=3003
ROUTER_PORT=3000

# Mock mode — bypass AI/LLM calls to test x402 payment loop without API credits
# MOCK_DECOMPOSITION=true
# MOCK_ANALYSIS=true
# MOCK_WRITING=true
